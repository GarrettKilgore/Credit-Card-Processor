import json
import boto3

dynamodb = boto3.resource('dynamodb')
merchant_table = dynamodb.Table('Merchant')

def lambda_handler(event, context):
    try:
        body = json.loads(event.get("body", "{}"))
    except:
        body = {}

    merchant_name = body.get("merchant_name")
    merchant_token = body.get("merchant_token")

    response = merchant_table.get_item(
        Key={
            "Name": merchant_name,
            "Token": merchant_token
        }
    )

    if "Item" in response:
        result = "Merchant Authorized."
    else:
        result = "Merchant Not Authorized."

    return {
        "statusCode": 200,
        "headers": {"Content-Type": "text/plain"},
        "body": result
    }
